{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "crons": [
    { "path": "/api/cron/weekly-content", "schedule": "0 6 * * 0" },
    { "path": "/api/cron/weekly-newsletter", "schedule": "0 8 * * 0" },
    { "path": "/api/cron/seo-audit", "schedule": "0 10 * * 3" },
    { "path": "/api/cron/daily-performance", "schedule": "0 12 * * *" },
    { "path": "/api/cron/welcome-sequence", "schedule": "0 11 * * *" },
    { "path": "/api/cron/health-check", "schedule": "0 13 * * *" }
  ]
}
